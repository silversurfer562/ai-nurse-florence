# Vercel Environment Configuration for AI Nurse Florence
# Add these as environment variables in Vercel dashboard

# Required for AI features
OPENAI_API_KEY=your-openai-api-key-here

# Enable live medical APIs for testing
USE_LIVE=1

# Vercel-specific settings
LOG_LEVEL=INFO
CORS_ORIGINS=*

# For testing, use in-memory storage (no Redis/PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./test.db
REDIS_URL=

# API security
LIFBAO4k5pHObTJBY3Jma55I5kSn8NtLnIwb7eXacUU
QTKM-JCx1wPoNFHS3UAWUAHVeB6tOOSjLUo1Oei9BAWAui4wSL5jsLm7maAoHKSx

# Rate limiting for testing
RATE_LIMIT_PER_MINUTE=60

# Optional external APIs
NCBI_API_KEY=
